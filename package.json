{
  "name": "il-folletto",
  "version": "0.1.0",
  "description": "macOS file cleaning daemon with complex pattern matching, TUI, and Web UI",
  "author": "Luca Maraschi <luca.maraschi@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucamaraschi/il-folletto.git"
  },
  "homepage": "https://github.com/lucamaraschi/il-folletto#readme",
  "bugs": {
    "url": "https://github.com/lucamaraschi/il-folletto/issues"
  },
  "type": "module",
  "bin": {
    "il-folletto": "./dist/index.js"
  },
  "files": [
    "dist",
    "resources",
    "web/dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/websocket": "^10.0.1",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "cosmiconfig": "^9.0.0",
    "fast-glob": "^3.3.2",
    "fastify": "^4.28.1",
    "ink": "^5.0.1",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "micromatch": "^4.0.8",
    "ms": "^2.1.3",
    "node-cron": "^3.0.3",
    "ora": "^8.1.0",
    "react": "^18.3.1",
    "trash": "^8.1.1",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.9",
    "@types/ms": "^0.7.34",
    "@types/node": "^22.7.4",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.5",
    "@types/ws": "^8.18.1",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "macos",
    "cleanup",
    "daemon",
    "file-management",
    "tui",
    "cli",
    "trash",
    "disk-space",
    "automation",
    "launchd",
    "cron",
    "file-watcher"
  ],
  "license": "MIT"
}
